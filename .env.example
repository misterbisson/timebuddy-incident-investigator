# Single-connection convenience path (CI, tests, or a lone Grafana instance): a
# read-only service account token (Viewer role recommended). For multiple Grafana
# endpoints or per-user auth, use the electron/ connection-manager app instead — see
# README.md's "Setup" and "Multiple Grafana connections" sections. Both paths can be
# used together; anything set here is merged with GRAFANA_CONNECTIONS_DIR's contents.
GRAFANA_URL=https://grafana.example.com
GRAFANA_TOKEN=glsa_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: directory the connection-manager app writes connections.json/credentials.json
# into (shown in that app's UI). Defaults to <DATA_DIR>/connections if unset.
GRAFANA_CONNECTIONS_DIR=

# Optional: verify Grafana's TLS certificate (default true). Only disable for
# self-signed internal instances you trust.
GRAFANA_TLS_VERIFY=true

# Optional: request timeout (ms) and concurrency cap for outgoing Grafana requests.
GRAFANA_REQUEST_TIMEOUT_MS=15000
GRAFANA_MAX_CONCURRENCY=4

# Optional: hard caps enforced on every query window request.
MAX_LOOKBACK_HOURS=720
MAX_DATA_POINTS=2000

# Optional: comma-separated regexes; label/annotation values matching any of
# these are redacted before being returned to the model.
REDACTION_PATTERNS=

# Local storage paths (JSONL alert store, JSON metric index cache, audit log).
DATA_DIR=.data

# Webhook listener (separate process, only needed for automated alert ingestion).
WEBHOOK_PORT=4318
