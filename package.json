{
  "name": "timebuddy-incident-investigator",
  "version": "0.4.0",
  "description": "Grafana Incident Review MCP server: read-only tools for AI-assisted incident investigation of dashboards, metrics, and logs.",
  "type": "module",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/misterbisson/timebuddy-incident-investigator.git"
  },
  "workspaces": [
    "electron"
  ],
  "main": "dist/server.js",
  "exports": {
    ".": "./dist/server.js"
  },
  "bin": {
    "timebuddy-incident-investigator": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "webhook": "tsx src/webhook/listener.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@liquescent/log-correlator-core": "0.0.7",
    "@liquescent/log-correlator-query-parser": "0.0.7",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "undici": "^8.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
